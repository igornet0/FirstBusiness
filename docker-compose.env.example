# Скопируйте в `.env` в корне репозитория — Docker Compose подставит переменные автоматически.

JWT_SECRET=замените-на-длинную-случайную-строку
DEEPSEEK_API_KEY=

# CORS: URL, с которого открывается фронт в браузере (по умолчанию http://localhost).
# Если меняете FRONTEND_PORT, задайте и FRONTEND_ORIGIN, например http://localhost:8080
# FRONTEND_ORIGIN=http://localhost
# FRONTEND_PORT=80
#
# Прямой доступ к backend с хоста: в docker-compose.yml раскомментируйте ports у сервиса backend.
